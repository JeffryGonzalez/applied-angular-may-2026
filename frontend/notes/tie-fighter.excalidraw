      "boundElements": null,
      "updated": 1779375859513,
      "link": null,
      "locked": false,
      "text": "Our goal as application developers: \n    - make the company more money - get code into production sooner.\n        - CI/CD - make frequent releases, build a little at a time, get feedback, rollback, move forward.\n    - reduce liability\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Our goal as application developers: \n    - make the company more money - get code into production sooner.\n        - CI/CD - make frequent releases, build a little at a time, get feedback, rollback, move forward.\n    - reduce liability\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
