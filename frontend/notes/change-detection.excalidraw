      "isDeleted": false,
      "boundElements": null,
      "updated": 1779219894979,
      "link": null,
      "locked": false,
      "text": "SSR -- Server Side Rendering - when a page is requested, the HTML for the dom is generated, sent to browser and the js takes over in the browser.\n        for each request. \nSSG -- static. ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SSR -- Server Side Rendering - when a page is requested, the HTML for the dom is generated, sent to browser and the js takes over in the browser.\n        for each request. \nSSG -- static. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
