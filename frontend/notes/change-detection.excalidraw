      "link": null,
      "locked": false,
      "text": "\"raw variables\"\n-- this will still work with zonless.\nIt just is super slow compared to signals.\n\n<h1>{{ isEven() }}</h1>\n\n{\n    isEven = signal(true); // producer\n    title = 'Sweetie';\n    current = 0;\n    increment() { \n      this.current += 1;\n    }\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"raw variables\"\n-- this will still work with zonless.\nIt just is super slow compared to signals.\n\n<h1>{{ isEven() }}</h1>\n\n{\n    isEven = signal(true); // producer\n    title = 'Sweetie';\n    current = 0;\n    increment() { \n      this.current += 1;\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
